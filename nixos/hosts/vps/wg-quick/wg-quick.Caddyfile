# WebDav proxy
#
# Note we need the webdav folder to be handled too not just sub paths
# otherwise Nautilus is confused by the root folder and we can't test with curl
webdav.hayzen.uk {
    log

    # Use socat from host
    reverse_proxy https://socat-https:9443 {
        transport http {
            tls_server_name {http.request.host}
            tls_insecure_skip_verify
        }

        header_up Host {host}
    }
}

