#
# Note that sub domains require a A or CNAME record in the DNS
#
# eg sub IN CNAME domain.com.
#

# Actual proxy
actual.hayzen.uk {
    log

    # Use socat from host
    reverse_proxy https://socat-https:9443 {
        transport http {
            tls_server_name {http.request.host}
            tls_insecure_skip_verify
        }

        header_up Host {host}
    }
}

